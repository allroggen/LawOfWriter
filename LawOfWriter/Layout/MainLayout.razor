@inherits LayoutComponentBase
@attribute [Authorize]
@using System.Security.Claims
@using LawOfWriter.Services
@inject Services.ThemeService ThemeService
@inject IJSRuntime Js
@inject IConfiguration Configuration
@inject IDialogService DialogService
@inject AuthService AuthService
@inject ConnectivityService ConnectivityService

@implements IAsyncDisposable

<MudThemeProvider DefaultScrollbar="true" IsDarkMode="@DarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
  <MudAppBar Elevation="1" Dense="true">
    <MudText Typo="Typo.h6" Class="ml-2" Style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
      Law Of Writer
      <span style="font-size: 0.65rem; opacity: 0.6; font-weight: 400; margin-left: 4px;">v@(_appVersion)</span>
    </MudText>

    <MudSpacer />

    @* ── Update notification ── *@
    @if (_updateAvailable)
    {
      <MudTooltip Text="Update verfügbar – tippen zum Installieren">
        <MudIconButton Icon="@Icons.Material.Filled.SystemUpdateAlt"
                       Color="Color.Warning"
                       OnClick="@ShowUpdateDialog"
                       aria-label="Update verfügbar – jetzt installieren" />
      </MudTooltip>
    }

    @* ── PWA install prompt ── *@
    @if (_installAvailable)
    {
      <MudTooltip Text="App installieren">
        <MudIconButton Icon="@Icons.Material.Filled.InstallMobile"
                       Color="Color.Info"
                       OnClick="@OnInstallClickedAsync"
                       aria-label="App auf Homescreen installieren" />
      </MudTooltip>
    }

    @* ── Connectivity / Sync status icon (nur wenn angemeldet) ── *@
    <AuthorizeView>
      <Authorized>
        <MudTooltip Text="@GetConnectivityTooltip()">
          <MudIconButton Icon="@GetConnectivityIcon()"
                         Color="@GetConnectivityColor()"
                         OnClick="@OnSyncIconClickedAsync"
                         Disabled="@(!ConnectivityService.IsOnline || ConnectivityService.IsSyncing)"
                         aria-label="Verbindungs- und Synchronisierungsstatus"
                         Class="@(ConnectivityService.IsSyncing ? "spin-icon" : "")" />
        </MudTooltip>
      </Authorized>
    </AuthorizeView>

    @* ── Dark mode toggle ── *@
    <MudTooltip Text="@(DarkMode ? "Light Mode" : "Dark Mode")">
      <MudToggleIconButton Icon="@Icons.Material.Filled.DarkMode"
                           ToggledIcon="@Icons.Material.Filled.LightMode"
                           Toggled="@DarkMode"
                           ToggledChanged="@OnDarkModeChanged"
                           aria-label="Dark Mode umschalten"
                           Color="Color.Inherit" />
    </MudTooltip>

    @* ── User menu ── *@
    <AuthorizeView Context="authContext">
      <Authorized>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
          <ActivatorContent>
            <MudIconButton Size="Size.Medium"
                           Style="padding: 0;"
                           title="@GetUserLabel(authContext.User)"
                           OnClick="@context.OpenAsync">
              @if (!string.IsNullOrEmpty(_avatarSrc))
              {
                <MudAvatar Size="Size.Medium">
                  <MudImage Src="@GetAvatarSrc()" Alt="Avatar" Style="width: 100%; height: 100%; object-fit: cover;" />
                </MudAvatar>
              }
              else
              {
                <MudIcon Icon="@Icons.Material.Filled.AccountCircle" />
              }
            </MudIconButton>
          </ActivatorContent>
          <ChildContent>
            <MudText Class="px-4 pt-3" Typo="Typo.subtitle2">@GetUserLabel(authContext.User)</MudText>
            <MudDivider Class="my-2" />
            <MudMenuItem Href="/game" Icon="@Icons.Material.Filled.SportsEsports">Spiele</MudMenuItem>
            <MudMenuItem Href="/hilfe" Icon="@Icons.Material.Filled.HelpOutline">Hilfe</MudMenuItem>
            <MudMenuItem Href="/logout" Icon="@Icons.Material.Filled.Logout">Abmelden</MudMenuItem>
          </ChildContent>
        </MudMenu>
      </Authorized>
      <NotAuthorized>
        <MudTooltip Text="Hilfe">
          <MudIconButton Icon="@Icons.Material.Filled.HelpOutline"
                         Color="Color.Inherit"
                         Href="/hilfe"
                         aria-label="Hilfe öffnen" />
        </MudTooltip>
      </NotAuthorized>
    </AuthorizeView>
  </MudAppBar>

  <MudMainContent>
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-3 pa-sm-4 pa-md-6">
      @Body
    </MudContainer>
  </MudMainContent>
</MudLayout>

@code {
  private MudTheme _theme = new();
  private bool DarkMode { get; set; }
  private bool _updateAvailable;
  private bool _installAvailable;
  private string _appVersion = "–";
  private DotNetObjectReference<MainLayout>? _dotNetRef;
  private string? _avatarSrc;
  private bool _connectivityInitialized;

  protected override async Task OnInitializedAsync()
  {
    _avatarSrc = await AuthService.GetImageBaseAsync();
    DarkMode = await ThemeService.GetDarkModeAsync(defaultValue: false);
    _appVersion = Configuration["AppVersion"] ?? "–";
    ConnectivityService.StateChanged += OnConnectivityStateChanged;
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      _dotNetRef = DotNetObjectReference.Create(this);
      await Js.InvokeVoidAsync("registerBlazorUpdateCallback", _dotNetRef);
      await Js.InvokeVoidAsync("registerInstallPromptCallback", _dotNetRef);

      // JS interop only works after first render
      if (!_connectivityInitialized)
      {
        _connectivityInitialized = true;
        await ConnectivityService.InitializeAsync();
        StateHasChanged();
      }
    }
  }

  private void OnConnectivityStateChanged() => InvokeAsync(StateHasChanged);

  private async Task OnSyncIconClickedAsync()
  {
    if (ConnectivityService.IsOnline && !ConnectivityService.IsSyncing)
      await ConnectivityService.SyncAllAsync();
  }

  // ── Connectivity icon helpers ──────────────────────────────────────────────

  private string GetConnectivityIcon()
  {
    if (!ConnectivityService.IsOnline) return Icons.Material.Filled.CloudOff;
    if (ConnectivityService.IsSyncing) return Icons.Material.Filled.Sync;
    if (ConnectivityService.UnsyncedCount > 0) return Icons.Material.Filled.CloudUpload;
    return Icons.Material.Filled.CloudDone;
  }

  private Color GetConnectivityColor()
  {
    if (!ConnectivityService.IsOnline) return Color.Error;
    if (ConnectivityService.IsSyncing) return Color.Primary;
    if (ConnectivityService.UnsyncedCount > 0) return Color.Warning;
    return Color.Success;
  }

  private string GetConnectivityTooltip()
  {
    if (!ConnectivityService.IsOnline) return "Offline – keine Verbindung";
    if (ConnectivityService.IsSyncing) return "Synchronisiere…";
    if (ConnectivityService.UnsyncedCount > 0)
      return $"{ConnectivityService.UnsyncedCount} Änderung(en) ausstehend – tippen zum Senden";
    return "Online – alle Daten aktuell";
  }

  // ── Service worker update ──────────────────────────────────────────────────

  [JSInvokable]
  public void NotifyUpdateAvailable()
  {
    _updateAvailable = true;
    InvokeAsync(StateHasChanged);
  }

  // ── PWA install prompt ─────────────────────────────────────────────────────

  [JSInvokable]
  public void NotifyInstallAvailable()
  {
    _installAvailable = true;
    InvokeAsync(StateHasChanged);
  }

  private async Task OnInstallClickedAsync()
  {
    var accepted = await Js.InvokeAsync<bool>("showInstallPrompt");
    if (accepted) _installAvailable = false;
  }

  private async Task ShowUpdateDialog()
  {
    var options = new DialogOptions
    {
      CloseOnEscapeKey = true,
      MaxWidth = MaxWidth.ExtraSmall,
      FullWidth = true
    };
    var dialog = await DialogService.ShowAsync<UpdateDialog>("Update verfügbar", options);
    var result = await dialog.Result;
    if (result is { Canceled: false })
      await Js.InvokeVoidAsync("applyServiceWorkerUpdate");
  }

  // ── Dark mode ──────────────────────────────────────────────────────────────

  private async Task OnDarkModeChanged(bool value)
  {
    DarkMode = value;
    await ThemeService.SetDarkModeAsync(value);
  }

  // ── User helpers ───────────────────────────────────────────────────────────

  private static string GetUserLabel(ClaimsPrincipal user)
    => user.FindFirst(ClaimTypes.Email)?.Value
       ?? user.FindFirst("vorname")?.Value
       ?? user.Identity?.Name
       ?? "Angemeldet";

  private string GetAvatarSrc()
  {
    if (string.IsNullOrEmpty(_avatarSrc)) return "";
    if (_avatarSrc.StartsWith("data:image")) return _avatarSrc;
    return $"data:image/png;base64,{_avatarSrc}";
  }

  public async ValueTask DisposeAsync()
  {
    ConnectivityService.StateChanged -= OnConnectivityStateChanged;
    _dotNetRef?.Dispose();
    await ConnectivityService.DisposeAsync();
  }
}


