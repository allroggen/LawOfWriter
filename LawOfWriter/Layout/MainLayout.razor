@inherits LayoutComponentBase
@attribute [Authorize]
@using System.Security.Claims
@inject Services.ThemeService ThemeService
@inject IJSRuntime Js
@inject IConfiguration Configuration
@inject IDialogService DialogService
@implements IAsyncDisposable

<MudThemeProvider DefaultScrollbar="true" IsDarkMode="@DarkMode" Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
  <MudAppBar Elevation="1" Dense="true">
    @* <MudIconButton Icon="@Icons.Material.Filled.Menu" *@
    @*                Color="Color.Inherit" *@
    @*                Edge="Edge.Start" *@
    @*                AriaLabel="Menü öffnen/schließen" *@
    @*                OnClick="@DrawerToggle" /> *@

    <MudText Typo="Typo.h6" Class="ml-2">
      Law Of Writer
      <span style="font-size: 0.65rem; opacity: 0.6; font-weight: 400; margin-left: 4px;">v@(_appVersion)</span>
    </MudText>

    <MudSpacer />

    @if (_updateAvailable)
    {
      <MudTooltip Text="Update verfügbar – jetzt installieren">
        <MudIconButton Icon="@Icons.Material.Filled.SystemUpdateAlt"
                       Color="Color.Warning"
                       OnClick="@ShowUpdateDialog"
                       AriaLabel="Update verfügbar" />
      </MudTooltip>
    }

    <MudTooltip Text="@(DarkMode ? "Light Mode" : "Dark Mode")">
      <MudToggleIconButton Icon="@Icons.Material.Filled.DarkMode"
                           ToggledIcon="@Icons.Material.Filled.LightMode"
                           T="bool"
                           Toggled="@DarkMode"
                           ToggledChanged="@OnDarkModeChanged"
                           AriaLabel="Dark Mode umschalten"
                           Color="Color.Inherit" />
    </MudTooltip>

    <AuthorizeView>
      <Authorized>
        <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
          <ActivatorContent>
            <MudTooltip Text="@GetUserLabel(context.User)">
              <MudIconButton Color="Color.Inherit" AriaLabel="Account-Menü">
                <MudAvatar Size="Size.Medium" Color="Color.Primary" Variant="Variant.Filled">
                  @GetUserInitials(context.User)
                </MudAvatar>
              </MudIconButton>
            </MudTooltip>
          </ActivatorContent>
          <ChildContent>
            <MudText Class="px-4 pt-3" Typo="Typo.subtitle2">@GetUserLabel(context.User)</MudText>
            <MudDivider Class="my-2" />
            <MudMenuItem Href="/game" Icon="@Icons.Material.Filled.SportsEsports">Spiele</MudMenuItem>
            @* <MudMenuItem Href="/losung" Icon="@Icons.Material.Filled.AccessTime">Verlosung</MudMenuItem> *@
            <MudMenuItem Href="/logout" Icon="@Icons.Material.Filled.Logout">Abmelden</MudMenuItem>
          </ChildContent>
        </MudMenu>
      </Authorized>
    </AuthorizeView>
  </MudAppBar>

  @* <MudDrawer @bind-Open="@_drawerOpen" *@
  @*            Variant="DrawerVariant.Temporary" *@
  @*            Breakpoint="Breakpoint.Md" *@
  @*            Elevation="2"> *@
  @*   <NavMenu /> *@
  @* </MudDrawer> *@

  <MudMainContent>
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-3 pa-sm-4 pa-md-6">
      @Body
    </MudContainer>
  </MudMainContent>
</MudLayout>

@code {
  bool _drawerOpen = false;
  private MudTheme _theme = new();
  public bool DarkMode { get; set; }
  private bool _updateAvailable;
  private string _appVersion = "–";
  private DotNetObjectReference<MainLayout>? _dotNetRef;

  protected override async Task OnInitializedAsync()
  {
    DarkMode = await ThemeService.GetDarkModeAsync(defaultValue: false);
    _appVersion = Configuration["AppVersion"] ?? "–";
  }

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender)
    {
      // Pass a DotNetObjectReference to JS so it can call back into THIS instance
      _dotNetRef = DotNetObjectReference.Create(this);
      await Js.InvokeVoidAsync("registerBlazorUpdateCallback", _dotNetRef);
    }
  }

  [JSInvokable]
  public void NotifyUpdateAvailable()
  {
    _updateAvailable = true;
    InvokeAsync(StateHasChanged);
  }

  private async Task ShowUpdateDialog()
  {
    var options = new DialogOptions
    {
      CloseOnEscapeKey = true,
      MaxWidth = MaxWidth.ExtraSmall,
      FullWidth = true
    };
    var dialog = await DialogService.ShowAsync<UpdateDialog>("Update verfügbar", options);
    var result = await dialog.Result;
    if (result is { Canceled: false })
    {
      await Js.InvokeVoidAsync("applyServiceWorkerUpdate");
    }
  }

  public async ValueTask DisposeAsync()
  {
    _dotNetRef?.Dispose();
    await Task.CompletedTask;
  }

  private async Task OnDarkModeChanged(bool value)
  {
    DarkMode = value;
    await ThemeService.SetDarkModeAsync(value);
  }

  void DrawerToggle()
  {
    _drawerOpen = !_drawerOpen;
  }

  private static string GetUserLabel(ClaimsPrincipal user)
  {
    return user.FindFirst(ClaimTypes.Email)?.Value
           ?? user.FindFirst("vorname")?.Value
           ?? user.Identity?.Name
           ?? "Angemeldet";
  }

  private static string GetUserInitials(ClaimsPrincipal user)
  {
    var label = GetUserLabel(user);
    if (string.IsNullOrWhiteSpace(label))
      return "?";

    var at = label.IndexOf('@');
    if (at > 0)
      label = label[..at];

    var parts = label
      .Replace('.', ' ')
      .Replace('_', ' ')
      .Replace('-', ' ')
      .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

    if (parts.Length == 0)
      return "?";

    if (parts.Length == 1)
    {
      var p = parts[0];
      return (p.Length >= 2 ? p[..2] : p[..1]).ToUpperInvariant();
    }

    var first = parts[0];
    var last = parts[^1];
    return $"{char.ToUpperInvariant(first[0])}{char.ToUpperInvariant(last[0])}";
  }
}

