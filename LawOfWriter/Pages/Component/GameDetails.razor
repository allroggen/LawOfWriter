@using LawOfWriter.DTO
@using LawOfWriter.Services
@inject IDialogService DialogService
@inject LocalDbService LocalDbService
@inject IGameDayActionService GameDayActionService
@inject ISnackbar Snackbar

<h3>@GameDay.GameDayDto.GameDay1.ToString("dd.MM.yyyy")</h3>

<MudDataGrid T="GameDayActionDto" Items="@GameDay.GameDayActionDtos"
            RowClick="@OnRowClick"
            RowHover="true">
    <Columns>
        <PropertyColumn Property="x=>x.User!.FullName" Title="Name" />
        <PropertyColumn Property="x=>x.Band" Title="Band" HeaderClass="hide-on-mobile" CellClass="hide-on-mobile" />
        <PropertyColumn Property="x=>x.Pumpe" Title="Pumpe" HeaderClass="hide-on-mobile" CellClass="hide-on-mobile" />
        <PropertyColumn Property="x=>x.Kranz" Title="Kranz" HeaderClass="hide-on-mobile" CellClass="hide-on-mobile" />
        <PropertyColumn Property="x=>x.Neuner" Title="Neuner" HeaderClass="hide-on-mobile" CellClass="hide-on-mobile" />
        <PropertyColumn Property="x=>x.Spiele" Title="Spiele" HeaderClass="hide-on-mobile" CellClass="hide-on-mobile" />
        @* <PropertyColumn Property="x=>x.Gesamt" Title="Gesamt" HeaderClass="hide-on-mobile" CellClass="hide-on-mobile" /> *@
    </Columns>
</MudDataGrid>

<style>
    /* Smartphone: nur FullName anzeigen */
    @@media (max-width: 600px) {
        .hide-on-mobile {
            display: none !important;
        }
    }
</style>

@code {
    [Parameter] public required GameApiDto GameDay { get; set; }
    [Parameter] public EventCallback OnActionChanged { get; set; }
    
    private async Task OpenEditDialog(GameDayActionDto item)
    {
        var parameters = new DialogParameters<EditGameActionDialog>
        {
            { x => x.GameAction, item }
        };
        
        var options = new DialogOptions 
        { 
            CloseButton = false, 
            MaxWidth = MaxWidth.Medium,
            FullWidth = true 
        };
        
        var dialog = await DialogService.ShowAsync<EditGameActionDialog>($"{item.User!.FullName}", parameters, options);
        var result = await dialog.Result;
        
        if (result is not { Canceled: true })
        {
            // 1. Lokal als unsynced speichern (Fallback falls API fehlschlägt)
            await LocalDbService.SaveGameDayActionAsUnsyncedAsync(item);

            // 2. Sofort zur API übertragen
            try
            {
                var ok = await GameDayActionService.SaveGameDayActionAsync(item);
                if (ok)
                {
                    await LocalDbService.MarkActionAsSyncedAsync(item.Id);
                    Snackbar.Add($"✅ {item.User?.FullName} erfolgreich übertragen.", Severity.Success);
                }
                else
                {
                    Snackbar.Add($"⚠️ Lokal gespeichert – Übertragung fehlgeschlagen.", Severity.Warning);
                }
            }
            catch
            {
                Snackbar.Add($"⚠️ Lokal gespeichert – Keine Verbindung zur API.", Severity.Warning);
            }

            await OnActionChanged.InvokeAsync();
            StateHasChanged();
        }
    }

    private Task OnRowClick(DataGridRowClickEventArgs<GameDayActionDto> args)
        => OpenEditDialog(args.Item);
}