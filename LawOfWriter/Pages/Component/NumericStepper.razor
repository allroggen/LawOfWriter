<div class="d-flex align-center justify-center gap-3" style="width:100%;">
    <MudFab StartIcon="@Icons.Material.Filled.Remove"
            Color="Color.Default"
            Size="Size.Medium"
            Style="touch-action: manipulation; min-width:44px; min-height:44px;"
            aria-label="Wert verringern"
            Disabled="@(Value is null or <= 0)"
            OnClick="Decrease" />

    <MudText Typo="Typo.h5" Align="Align.Center"
             Style="min-width:56px; font-variant-numeric: tabular-nums; user-select:none;">
        @(Value?.ToString() ?? "0")
    </MudText>

    <MudFab StartIcon="@Icons.Material.Filled.Add"
            Color="Color.Primary"
            Size="Size.Medium"
            Style="touch-action: manipulation; min-width:44px; min-height:44px;"
            aria-label="Wert erhöhen"
            OnClick="Increase" />
</div>

@code {
    [Parameter] public int? Value { get; set; }
    [Parameter] public EventCallback<int?> ValueChanged { get; set; }

    private Task Increase()
        => ValueChanged.InvokeAsync((Value ?? 0) + 1);

    private Task Decrease()
        => ValueChanged.InvokeAsync(Math.Max(0, (Value ?? 0) - 1));
}