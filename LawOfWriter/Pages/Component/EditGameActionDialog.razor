@using LawOfWriter.DTO

<MudDialog MaxWidth="MaxWidth.Small" FullWidth="true">
    <DialogContent>

        <MudGrid Spacing="2">

            <!-- Benutzer -->
            <MudItem xs="12">
                <MudTextField Label="Benutzer"
                              Value="@GameAction.User?.FullName"
                              ReadOnly="true"
                              Variant="Variant.Filled"
                              FullWidth="true" />
            </MudItem>

            <!-- Zahlenfelder mit Plus / Minus -->
            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Band</MudText>
                <NumericStepper @bind-Value="GameAction.Band" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Pumpe</MudText>
                <NumericStepper @bind-Value="GameAction.Pumpe" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Kranz</MudText>
                <NumericStepper @bind-Value="GameAction.Kranz" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Neuner</MudText>
                <NumericStepper @bind-Value="GameAction.Neuner" />
            </MudItem>

            <MudItem xs="12" sm="6">
                <MudText Typo="Typo.subtitle2">Spiele</MudText>
                <NumericStepperDecimal @bind-Value="GameAction.Spiele"
                                       Step="0.5M" />
            </MudItem>

        </MudGrid>

    </DialogContent>

    <!-- Actions -->
    <DialogActions>
        <div class="d-flex flex-column flex-sm-row gap-2" style="width: 100%;">
            <MudButton FullWidth="true"
                       Variant="Variant.Outlined"
                       OnClick="Cancel">
                Abbrechen
            </MudButton>

            <MudButton FullWidth="true"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       OnClick="Save">
                Speichern
            </MudButton>
        </div>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance  MudDialog { get; set; } = null!;

    [Parameter]
    public required GameDayActionDto GameAction { get; set; }

    private void Cancel()
        => MudDialog.Cancel();

    private void Save()
        => MudDialog.Close(DialogResult.Ok(GameAction));
}