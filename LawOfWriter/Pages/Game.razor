@page "/game"
@using LawOfWriter.DTO
@using LawOfWriter.Services
@using LawOfWriter.Pages.Component
@inject ApiService apiService
@attribute [Authorize]


@if (!_showDetails)
{
    @if (IsLoading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary"/>
    }
    else
    {
        <MudDataGrid T="GameApiDto" Items="@_gameDays" @bind-SelectedItem="_selectedGameDay" SelectOnRowClick="true">
            <Columns>
                <PropertyColumn Property="p=>p.GameDayDto.Id"/>
                <PropertyColumn Property="p=>p.GameDayDto.GameDay1"/>
                <TemplateColumn>
                    <CellTemplate>
                        <MudButton OnClick="@(() => ShowDetails(context.Item))" Variant="Variant.Text">Details
                        </MudButton>
                    </CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }
}
else if (_selectedGameDay is not null)
{
    <MudButton OnClick="@BackToList" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">Zurück
    </MudButton>
    <GameDetails gameDay="_selectedGameDay"/>
}

@code {

    private List<GameApiDto>? _gameDays = new();
    private GameApiDto? _selectedGameDay;
    private bool _showDetails = false;
    public bool IsLoading { get; set; } = true;

    private void ShowDetails(GameApiDto gameDay)
    {
        _selectedGameDay = gameDay;
        _showDetails = true;
    }

    private void BackToList()
    {
        _showDetails = false;
        _selectedGameDay = null;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadGameData();
    }


    private async Task LoadGameData()
    {
        try
        {
            IsLoading = true;
            _gameDays = await apiService.GetAsync<List<GameApiDto>>("data/game");
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            throw;
        }
    }

}