@page "/game"
@using LawOfWriter.DTO
@using LawOfWriter.Services
@using LawOfWriter.Pages.Component
@inject ApiService ApiService
@inject IGameDayActionService GameDayActionService
@inject LocalDbService LocalDbService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthService AuthService
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">

    @if (!_showDetails) {
        <MudStack Spacing="2">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudText Typo="Typo.h5">Spieltage</MudText>
                <MudTooltip Text="Neu laden">
                    <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                   Color="Color.Primary"
                                   Disabled="@_refreshing"
                                   OnClick="@RefreshAllAsync" />
                </MudTooltip>
            </MudStack>

            @if (IsLoading) {
                <MudPaper Class="pa-6 d-flex justify-center" Elevation="0">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large"/>
                </MudPaper>
            }
            else if (_gameDays is null || _gameDays.Count == 0) {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Keine Daten verfügbar.
                </MudAlert>
            }
            else {
                <MudGrid Spacing="2">
                    @foreach (var item in _gameDays) {
                        var gameId = item.GameDayDto.Id;
                        var status = _syncStatus.GetValueOrDefault(gameId);
                        var total = status.Total;
                        var synced = status.Synced;
                        var allSynced = total > 0 && synced == total;
                        var badgeColor = allSynced ? Color.Success : (synced > 0 ? Color.Warning : Color.Error);
                        var lockedByOther = IsLockedByOther(gameId);

                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudCard Elevation="1" Class="h-100">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                            @if (lockedByOther) {
                                                <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Error" Size="Size.Small" />
                                            }
                                            <MudText Typo="Typo.body2" Color="@(lockedByOther ? Color.Error : Color.Secondary)">
                                                @item.GameDayDto.GameDay1.ToString("dd.MM.yyyy")
                                            </MudText>
                                        </MudStack>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @if (total > 0) {
                                            <MudTooltip Text="@($"{synced} von {total} übertragen")">
                                                <MudChip T="string" Color="@badgeColor" Size="Size.Small" Variant="Variant.Filled">
                                                    @synced / @total
                                                </MudChip>
                                            </MudTooltip>
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>

                                <MudCardActions Class="pa-3 pt-0 d-flex gap-2">
                                    @if (_lockCheckLoading) {
                                        <MudButton FullWidth="true"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Default"
                                                   Disabled="true">
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/>
                                            Prüfe…
                                        </MudButton>
                                    }
                                    else if (lockedByOther) {
                                        <MudButton FullWidth="true"
                                                   Variant="Variant.Outlined"
                                                   Color="Color.Warning"
                                                   StartIcon="@Icons.Material.Filled.PersonSearch"
                                                   OnClick="@(() => ShowLockedByUserAsync(gameId))">
                                            Wer schreibt?
                                        </MudButton>
                                    }
                                    else {
                                        <MudButton FullWidth="true"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => ShowDetails(item))">
                                            Öffnen
                                        </MudButton>
                                        <MudTooltip Text="@(allSynced ? "Alle bereits übertragen" : "Änderungen zur API übertragen")">
                                            <MudButton FullWidth="true"
                                                       Variant="Variant.Outlined"
                                                       Color="@(allSynced ? Color.Success : Color.Secondary)"
                                                       Disabled="@(_transferring == gameId)"
                                                       StartIcon="@(allSynced ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudUpload)"
                                                       OnClick="@(() => TransferToApiAsync(item))">
                                                @if (_transferring == gameId) {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1"/>
                                                }
                                                Übertragen
                                            </MudButton>
                                        </MudTooltip>
                                    }
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
    else if (_selectedGameDay is not null) {
        <MudPaper Class="pa-2 mb-3 d-flex align-center" Elevation="0"
                  Style="position: sticky; top: 0; z-index: 5;">
            <MudButton OnClick="@BackToListAsync" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">
                Zurück
            </MudButton>
            <MudSpacer/>
            @{
                var detailGameId = _selectedGameDay!.GameDayDto.Id;
                var detailStatus = _syncStatus.GetValueOrDefault(detailGameId);
                var detailSynced = detailStatus.Synced;
                var detailTotal = detailStatus.Total;
                var detailAllSynced = detailTotal > 0 && detailSynced == detailTotal;
                var detailColor = detailAllSynced ? Color.Success : (detailSynced > 0 ? Color.Warning : Color.Error);
            }
            <MudTooltip Text="@($"{detailSynced} von {detailTotal} Datensätze übertragen")">
                <MudChip T="string" Color="@detailColor" Size="Size.Small" Variant="Variant.Filled"
                         Icon="@(detailAllSynced ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudUpload)">
                    @detailSynced / @detailTotal übertragen
                </MudChip>
            </MudTooltip>
            <MudTooltip Text="Spieltag zurücksetzen">
                <MudIconButton Icon="@Icons.Material.Filled.RestartAlt"
                               Color="Color.Error"
                               Size="Size.Small"
                               OnClick="@(() => ConfirmResetGameDayAsync(_selectedGameDay!))" />
            </MudTooltip>
        </MudPaper>

        <GameDetails GameDay="_selectedGameDay" OnActionChanged="@RefreshSyncStatusAsync"/>
    }

</MudContainer>

@code {

    private List<GameApiDto>? _gameDays = new();
    private GameApiDto? _selectedGameDay;
    private bool _showDetails = false;
    public bool IsLoading { get; set; } = true;

    // gameId → (Total, Synced)
    private Dictionary<int, (int Total, int Synced)> _syncStatus = new();
    private int? _transferring = null;

    // gameId → Lock-Status (ob ein anderer Schreiber eingetragen ist)
    private Dictionary<int, LockGameResponseDto> _lockStatus = new();
    // Snapshot: Zustand VOR unserem eigenen Lock-Setzen (true = wir waren schon Schreiber beim Laden)
    private HashSet<int> _alreadyOwnWriter = new();
    private string? _currentUserId;
    private bool _lockCheckLoading = true;
    private bool _refreshing;
    
    private async Task ShowDetails(GameApiDto gameDay) {
        var gameId = gameDay.GameDayDto.Id;

        // _lockStatus wurde mit echter UserId befüllt → IsLockedByOther bereits korrekt
        // _alreadyOwnWriter = beim Laden war kein anderer Schreiber eingetragen (wir werden es jetzt erst)
        // Wenn wir beim Laden bereits selbst Schreiber waren → direkt öffnen

        if (IsLockedByOther(gameId)) {
            // Sollte eigentlich nicht passieren (Button wird ausgeblendet), aber als Sicherheit
            _lockStatus.TryGetValue(gameId, out var s);
            var since = s?.LockedSince?.ToString("dd.MM.yyyy HH:mm") ?? "unbekannt";
            await DialogService.ShowMessageBox(
                title: "Spieltag gesperrt",
                message: $"Ein anderer Schreiber bearbeitet diesen Spieltag bereits seit {since}.",
                yesText: "OK",
                options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
            return;
        }

        // War beim Laden noch kein Schreiber eingetragen → nachfragen
        if (!_alreadyOwnWriter.Contains(gameId)) {
            var confirmed = await DialogService.ShowMessageBox(
                title: "Als Schreiber eintragen?",
                message: "Du wirst als Schreiber für diesen Spieltag eingetragen. Möchtest du fortfahren?",
                yesText: "Ja",
                cancelText: "Nein",
                options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });

            if (confirmed is not true) return;

            // Lock jetzt tatsächlich setzen
            try {
                await ApiService.PostAsync<LockGameDto, LockGameResponseDto>(
                    "data/checkgame",
                    new LockGameDto { GameId = gameId, UserId = _currentUserId! });
                // Ab jetzt sind wir Schreiber → künftige Klicks ohne Dialog
                _alreadyOwnWriter.Add(gameId);
            }
            catch { /* Offline – trotzdem öffnen */ }
        }

        _selectedGameDay = gameDay;
        _showDetails = true;
    }

    private async Task ConfirmResetGameDayAsync(GameApiDto gameDay) {
        var date = gameDay.GameDayDto.GameDay1.ToString("dd.MM.yyyy");
        var confirmed = await DialogService.ShowMessageBox(
            title: $"Spieltag {date} zurücksetzen",
            message: $"Alle lokalen Änderungen für den {date} werden verworfen und die Originaldaten vom Server wiederhergestellt. Nicht übertragene Änderungen gehen verloren.",
            yesText: "Zurücksetzen",
            cancelText: "Abbrechen",
            options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true }
        );

        if (confirmed is not true) return;

        // Lokale Actions und GameDay löschen
        var gameId = gameDay.GameDayDto.Id;
        var localActions = await LocalDbService.GetActionsByGameIdAsync(gameId);
        foreach (var a in localActions)
            await LocalDbService.DeleteGameDayActionAsync(a.Id);
        await LocalDbService.DeleteGameDayAsync(gameId);

        // Zurück zur Liste + Ladezustand anzeigen während Server-Daten kommen
        _showDetails = false;
        _selectedGameDay = null;
        _gameDays = null;
        IsLoading = true;
        StateHasChanged();

        Snackbar.Add($"Spieltag {date} wird vom Server wiederhergestellt…", Severity.Info);
        await LoadGameData();
        Snackbar.Add($"✅ Spieltag {date} wiederhergestellt.", Severity.Success);
    }

    private async Task BackToListAsync() {
        // Noch offene unsynced Actions des aktuellen Spieltags übertragen
        if (_selectedGameDay is not null)
        {
            await TransferRemainingAsync(_selectedGameDay);
        }
        _showDetails = false;
        _selectedGameDay = null;
    }

    /// <summary>
    /// Überträgt alle noch unsynced Actions eines Spieltags zur API (stiller Hintergrund-Sync).
    /// </summary>
    private async Task TransferRemainingAsync(GameApiDto gameDay) {
        var gameId = gameDay.GameDayDto.Id;
        var pending = (await LocalDbService.GetActionsByGameIdAsync(gameId))
            .Where(a => !a.IsSynced).ToList();

        if (pending.Count == 0) return;

        var success = 0;
        foreach (var action in pending)
        {
            var dto = gameDay.GameDayActionDtos.FirstOrDefault(d => d.Id == action.Id);
            if (dto is null) continue;

            try
            {
                var ok = await GameDayActionService.SaveGameDayActionAsync(dto);
                if (ok)
                {
                    await LocalDbService.MarkActionAsSyncedAsync(action.Id);
                    success++;
                }
            }
            catch { /* Offline – beim nächsten Mal */ }
        }

        if (success > 0)
            Snackbar.Add($"✅ {success} von {pending.Count} Datensätze beim Verlassen übertragen.", Severity.Success);
        else if (pending.Count > 0)
            Snackbar.Add($"⚠️ {pending.Count} Datensätze noch nicht übertragen – bitte manuell synchronisieren.", Severity.Warning);

        await RefreshSyncStatusAsync();
    }

    protected override async Task OnInitializedAsync() {
        _currentUserId = await AuthService.GetUserIdAsync();
        await LoadGameData();
        await CheckAllLockStatusAsync();
    }

    private async Task RefreshAllAsync() {
        _refreshing = true;
        _lockCheckLoading = true;
        _lockStatus.Clear();
        StateHasChanged();

        try {
            await LoadGameData();
            await CheckAllLockStatusAsync();
        }
        finally {
            _refreshing = false;
            StateHasChanged();
        }
    }

    private async Task LoadGameData() {
        try {
            IsLoading = true;

            // ── Schritt 1: Lokale Daten sofort anzeigen ──────────────────────
            var localData = await LocalDbService.GetAllLocalGameApisAsync();
            if (localData.Count > 0) {
                _gameDays = localData;
                IsLoading = false;
                await RefreshSyncStatusAsync();
            }
            // Wenn keine lokalen Daten → IsLoading bleibt true bis API antwortet

            // ── Schritt 2: API im Hintergrund abfragen ────────────────────────
            var serverData = await ApiService.GetAsync<List<GameApiDto>>("data/game");
            if (serverData is null) return;

            // Neue Spieltage einfügen; bestehende nur aktualisieren wenn alle
            // Actions bereits synced sind (= keine lokalen Änderungen offen)
            foreach (var serverGame in serverData)
            {
                var gameId = serverGame.GameDayDto.Id;
                var existing = _gameDays?.FirstOrDefault(g => g.GameDayDto.Id == gameId);

                if (existing is null)
                {
                    // Neuer Spieltag – direkt aus Server übernehmen
                    await LocalDbService.SaveGameApiAsync(serverGame, isSynced: false);
                    _gameDays ??= [];
                    _gameDays.Add(serverGame);
                }
                else
                {
                    // Spieltag existiert lokal – nur Actions aktualisieren die bereits synced sind
                    // (unsynced = lokal geändert → nicht überschreiben)
                    var (total, synced) = await LocalDbService.GetSyncStatusAsync(gameId);
                    if (total == 0 || total == synced)
                    {
                        // Alle synced oder noch keine lokalen Daten → Server-Version übernehmen
                        await LocalDbService.SaveGameApiAsync(serverGame, isSynced: false);
                        var idx = _gameDays!.IndexOf(existing);
                        _gameDays[idx] = serverGame;
                    }
                    else
                    {
                        // Es gibt unsynced Actions → GameDay-Meta aktualisieren,
                        // aber einzelne Actions nur ersetzen wenn sie synced sind
                        await LocalDbService.SaveGameDayAsync(serverGame.GameDayDto);
                        foreach (var serverAction in serverGame.GameDayActionDtos)
                        {
                            var localAction = await LocalDbService.GetGameDayActionAsync(serverAction.Id);
                            if (localAction is null || localAction.IsSynced)
                            {
                                // Neu oder bereits synced → Server-Version speichern
                                await LocalDbService.SaveGameDayActionAsync(serverAction, isSynced: false);
                                // In-Memory DTO aktualisieren
                                var dtoIdx = existing.GameDayActionDtos
                                    .FindIndex(d => d.Id == serverAction.Id);
                                if (dtoIdx >= 0)
                                    existing.GameDayActionDtos[dtoIdx] = serverAction;
                                else
                                    existing.GameDayActionDtos.Add(serverAction);
                            }
                            // localAction.IsSynced == false → lokale Änderung behalten
                        }
                    }
                }
            }

            IsLoading = false;
            await RefreshSyncStatusAsync();
        }
        catch (Exception e) {
            Console.WriteLine(e);
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshSyncStatusAsync() {
        if (_gameDays is null) return;
        foreach (var g in _gameDays)
        {
            _syncStatus[g.GameDayDto.Id] = await LocalDbService.GetSyncStatusAsync(g.GameDayDto.Id);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task TransferToApiAsync(GameApiDto gameDay) {
        var gameId = gameDay.GameDayDto.Id;
        var pending = (await LocalDbService.GetActionsByGameIdAsync(gameId))
            .Where(a => !a.IsSynced).ToList();

        if (pending.Count == 0) {
            Snackbar.Add("Alle Datensätze bereits übertragen.", Severity.Info);
            return;
        }

        _transferring = gameId;
        StateHasChanged();

        try {
            await TransferRemainingAsync(gameDay);
        }
        finally {
            _transferring = null;
            await RefreshSyncStatusAsync();
        }
    }

    /// <summary>
    /// Prüft den Lock-Status für alle geladenen Spieltage.
    /// </summary>
    private async Task CheckAllLockStatusAsync() {
        if (_gameDays is null || string.IsNullOrEmpty(_currentUserId)) {
            _lockCheckLoading = false;
            return;
        }

        _lockCheckLoading = true;
        _alreadyOwnWriter.Clear();

        foreach (var game in _gameDays) {
            try {
                var response = await ApiService.PostAsync<LockGameDto, LockGameResponseDto>(
                    "data/checkgame",
                    new LockGameDto { GameId = game.GameDayDto.Id, UserId = _currentUserId });

                if (response is not null) {
                    _lockStatus[game.GameDayDto.Id] = response;
                    // Wenn wir selbst bereits Schreiber sind → merken, kein Dialog nötig
                    if (response.IsLocked && response.UserId == _currentUserId)
                        _alreadyOwnWriter.Add(game.GameDayDto.Id);
                }
            }
            catch {
                // Offline – kein Lock-Status verfügbar
            }
        }

        _lockCheckLoading = false;
        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Prüft ob ein Spieltag von einem anderen Benutzer gesperrt ist.
    /// </summary>
    private bool IsLockedByOther(int gameId) {
        return _lockStatus.TryGetValue(gameId, out var status)
               && status.IsLocked
               && status.UserId != _currentUserId;
    }

    /// <summary>
    /// Fragt den Benutzernamen des Schreibers ab und zeigt ihn in einem Dialog an.
    /// </summary>
    private async Task ShowLockedByUserAsync(int gameId) {
        if (!_lockStatus.TryGetValue(gameId, out var status) || status.UserId is null) return;

        try {
            var userName = await ApiService.PostStringAsync(
                "data/getusername", status.UserId) ?? "Unbekannt";

            var since = status.LockedSince?.ToString("dd.MM.yyyy HH:mm") ?? "unbekannt";
            await DialogService.ShowMessageBox(
                title: "Spieltag gesperrt",
                message: $"Schreiber: {userName}\nSeit: {since}",
                yesText: "OK",
                options: new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true });
        }
        catch (Exception e) {
            Snackbar.Add($"⚠️ Benutzername konnte nicht abgefragt werden. ({e.Message})", Severity.Warning);
        }
    }
}
