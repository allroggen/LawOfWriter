@page "/game"
@using LawOfWriter.DTO
@using LawOfWriter.Services
@using LawOfWriter.Pages.Component
@inject ApiService ApiService
@inject LocalDbService LocalDbService
@inject ISnackbar Snackbar
@attribute [Authorize]

<MudContainer MaxWidth="MaxWidth.Large" Class="py-4">

    @if (!_showDetails) {
        <MudStack Spacing="2">
            <MudText Typo="Typo.h5">Spieltage</MudText>

            @if (IsLoading) {
                <MudPaper Class="pa-6 d-flex justify-center" Elevation="0">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large"/>
                </MudPaper>
            }
            else if (_gameDays is null || _gameDays.Count == 0) {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Keine Daten verfügbar.
                </MudAlert>
            }
            else {
                <MudGrid Spacing="2">
                    @foreach (var item in _gameDays) {
                        var gameId = item.GameDayDto.Id;
                        var status = _syncStatus.GetValueOrDefault(gameId);
                        var total = status.Total;
                        var synced = status.Synced;
                        var allSynced = total > 0 && synced == total;
                        var badgeColor = allSynced ? Color.Success : (synced > 0 ? Color.Warning : Color.Error);

                        <MudItem xs="12" sm="6" md="4" lg="3">
                            <MudCard Elevation="1" Class="h-100">
                                <MudCardHeader>
                                    <CardHeaderContent>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            @item.GameDayDto.GameDay1.ToString("dd.MM.yyyy")
                                        </MudText>
                                    </CardHeaderContent>
                                    <CardHeaderActions>
                                        @if (total > 0) {
                                            <MudTooltip Text="@($"{synced} von {total} übertragen")">
                                                <MudChip T="string" Color="@badgeColor" Size="Size.Small" Variant="Variant.Filled">
                                                    @synced / @total
                                                </MudChip>
                                            </MudTooltip>
                                        }
                                    </CardHeaderActions>
                                </MudCardHeader>

                                <MudCardActions Class="pa-3 pt-0 d-flex gap-2">
                                    <MudButton FullWidth="true"
                                               Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="@(() => ShowDetails(item))">
                                        Öffnen
                                    </MudButton>
                                    <MudTooltip Text="@(allSynced ? "Alle bereits übertragen" : "Änderungen zur API übertragen")">
                                        <MudButton FullWidth="true"
                                                   Variant="Variant.Outlined"
                                                   Color="@(allSynced ? Color.Success : Color.Secondary)"
                                                   Disabled="@(_transferring == gameId)"
                                                   StartIcon="@(allSynced ? Icons.Material.Filled.CloudDone : Icons.Material.Filled.CloudUpload)"
                                                   OnClick="@(() => TransferToApiAsync(item))">
                                            @if (_transferring == gameId) {
                                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1"/>
                                            }
                                            Übertragen
                                        </MudButton>
                                    </MudTooltip>
                                </MudCardActions>
                            </MudCard>
                        </MudItem>
                    }
                </MudGrid>
            }
        </MudStack>
    }
    else if (_selectedGameDay is not null) {
        <MudPaper Class="pa-2 mb-3 d-flex align-center" Elevation="0"
                  Style="position: sticky; top: 0; z-index: 5;">
            <MudButton OnClick="@BackToList" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack">
                Zurück
            </MudButton>
            <MudSpacer/>
            <MudText Typo="Typo.subtitle2">Details</MudText>
        </MudPaper>

        <GameDetails GameDay="_selectedGameDay" OnActionChanged="@RefreshSyncStatusAsync"/>
    }

</MudContainer>

@code {

    private List<GameApiDto>? _gameDays = new();
    private GameApiDto? _selectedGameDay;
    private bool _showDetails = false;
    public bool IsLoading { get; set; } = true;

    // gameId → (Total, Synced)
    private Dictionary<int, (int Total, int Synced)> _syncStatus = new();
    private int? _transferring = null;

    private void ShowDetails(GameApiDto gameDay) {
        _selectedGameDay = gameDay;
        _showDetails = true;
    }

    private void BackToList() {
        _showDetails = false;
        _selectedGameDay = null;
    }

    protected override async Task OnInitializedAsync() {
        await LoadGameData();
    }

    private async Task LoadGameData() {
        try {
            IsLoading = true;

            // ── Schritt 1: Lokale Daten sofort anzeigen ──────────────────────
            var localData = await LocalDbService.GetAllLocalGameApisAsync();
            if (localData.Count > 0) {
                _gameDays = localData;
                IsLoading = false;
                await RefreshSyncStatusAsync();
            }

            // ── Schritt 2: API im Hintergrund abfragen ────────────────────────
            var serverData = await ApiService.GetAsync<List<GameApiDto>>("data/game");
            if (serverData is null) return;

            // Neue Spieltage einfügen; bestehende nur aktualisieren wenn alle
            // Actions bereits synced sind (= keine lokalen Änderungen offen)
            foreach (var serverGame in serverData)
            {
                var gameId = serverGame.GameDayDto.Id;
                var existing = _gameDays?.FirstOrDefault(g => g.GameDayDto.Id == gameId);

                if (existing is null)
                {
                    // Neuer Spieltag – direkt aus Server übernehmen
                    await LocalDbService.SaveGameApiAsync(serverGame, isSynced: false);
                    _gameDays ??= [];
                    _gameDays.Add(serverGame);
                }
                else
                {
                    // Spieltag existiert lokal – nur Actions aktualisieren die bereits synced sind
                    // (unsynced = lokal geändert → nicht überschreiben)
                    var (total, synced) = await LocalDbService.GetSyncStatusAsync(gameId);
                    if (total == 0 || total == synced)
                    {
                        // Alle synced oder noch keine lokalen Daten → Server-Version übernehmen
                        await LocalDbService.SaveGameApiAsync(serverGame, isSynced: false);
                        var idx = _gameDays!.IndexOf(existing);
                        _gameDays[idx] = serverGame;
                    }
                    else
                    {
                        // Es gibt unsynced Actions → GameDay-Meta aktualisieren,
                        // aber einzelne Actions nur ersetzen wenn sie synced sind
                        await LocalDbService.SaveGameDayAsync(serverGame.GameDayDto);
                        foreach (var serverAction in serverGame.GameDayActionDtos)
                        {
                            var localAction = await LocalDbService.GetGameDayActionAsync(serverAction.Id);
                            if (localAction is null || localAction.IsSynced)
                            {
                                // Neu oder bereits synced → Server-Version speichern
                                await LocalDbService.SaveGameDayActionAsync(serverAction, isSynced: false);
                                // In-Memory DTO aktualisieren
                                var dtoIdx = existing.GameDayActionDtos
                                    .FindIndex(d => d.Id == serverAction.Id);
                                if (dtoIdx >= 0)
                                    existing.GameDayActionDtos[dtoIdx] = serverAction;
                                else
                                    existing.GameDayActionDtos.Add(serverAction);
                            }
                            // localAction.IsSynced == false → lokale Änderung behalten
                        }
                    }
                }
            }

            IsLoading = false;
            await RefreshSyncStatusAsync();
        }
        catch (Exception e) {
            Console.WriteLine(e);
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshSyncStatusAsync() {
        if (_gameDays is null) return;
        foreach (var g in _gameDays)
        {
            _syncStatus[g.GameDayDto.Id] = await LocalDbService.GetSyncStatusAsync(g.GameDayDto.Id);
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task TransferToApiAsync(GameApiDto gameDay) {
        var gameId = gameDay.GameDayDto.Id;
        _transferring = gameId;
        StateHasChanged();

        try {
            var unsynced = await LocalDbService.GetActionsByGameIdAsync(gameId);
            var pending = unsynced.Where(a => !a.IsSynced).ToList();

            if (pending.Count == 0) {
                Snackbar.Add("Alle Datensätze bereits übertragen.", Severity.Info);
                return;
            }

            var success = 0;
            foreach (var action in pending)
            {
                // Den originalen DTO aus dem in-memory GameDay verwenden
                var dto = gameDay.GameDayActionDtos.FirstOrDefault(d => d.Id == action.Id);
                if (dto is null) continue;

                var ok = await ApiService.PostAsync<GameDayActionDto>("data/gameaction", dto);
                if (ok) {
                    await LocalDbService.MarkActionAsSyncedAsync(action.Id);
                    success++;
                }
            }

            if (success == pending.Count)
                Snackbar.Add($"✅ Alle {success} Datensätze erfolgreich übertragen.", Severity.Success);
            else
                Snackbar.Add($"⚠️ {success} von {pending.Count} übertragen. Bitte erneut versuchen.", Severity.Warning);
        }
        catch (Exception ex) {
            Console.WriteLine(ex);
            Snackbar.Add("Fehler beim Übertragen zur API.", Severity.Error);
        }
        finally {
            _transferring = null;
            await RefreshSyncStatusAsync();
        }
    }
}